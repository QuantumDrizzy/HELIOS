# Universal .gitignore for Drizzy's Research Ecosystem

# Rust / C++ Build Artifacts
target/
**/target/
build/
bin/
*.exe
*.dll
*.so
*.dylib
*.pdb
*.rlib
*.rmeta

# Python & AI Metadata
__pycache__/
*.py[cod]
*$py.class
venv/
.env
.venv
env/
.claude/
.gemini/
.agents/
.qwen/
.anthropic/
CLAUDE.md

# IDEs & System
.vscode/
.idea/
.gradle/
.kotlin/
*.iml
.DS_Store
Thumbs.db
desktop.ini

# Data & Logs
*.log
data/*.json
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal
# Regenerable training intermediates (recreated by ai/dataset_generator.py + ai/train.py)
data/train_sequences.pt
data/val_sequences.pt
data/*.png
# Batteries-included: SHIP the trained model (data/helios_predictor.pt — no ignore rule)
# and the PVGIS input CSV so a fresh clone runs OFFLINE with no re-training.
data/*.csv
!data/pvgis_murcia_tmy.csv
!data/.gitkeep
out/
dist/

# Cargo worktrees / claude worktrees
.claude/
