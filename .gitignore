# Universal .gitignore for Drizzy's Research Ecosystem

# Rust / C++ Build Artifacts
target/
**/target/
build/
bin/
*.exe
*.dll
*.so
*.dylib
*.pdb
*.rlib
*.rmeta

# Python & AI Metadata
__pycache__/
*.py[cod]
*$py.class
venv/
.env
.venv
env/
.claude/
.gemini/
.agents/
.qwen/
.anthropic/
CLAUDE.md

# IDEs & System
.vscode/
.idea/
.gradle/
.kotlin/
*.iml
.DS_Store
Thumbs.db
desktop.ini

# Data & Logs
*.log
data/*.csv
data/*.json
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal
!data/.gitkeep
out/
dist/

# Cargo worktrees / claude worktrees
.claude/
